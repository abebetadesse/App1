import React from "react";
/* eslint-disable no-unused-vars */
import App from './App.jsx';
import './index.css';

// ----------------------------------------------------------------------
// 1. SAFELY IMPORT CONTEXTS (with fallbacks)
// ----------------------------------------------------------------------
let AuthProvider, ThemeProvider;

try {
  // Use dynamic import for better error handling
  const AuthContextModule = require('./contexts/AuthContext');
  AuthProvider = AuthContextModule.AuthProvider || AuthContextModule.default;
  if (!AuthProvider) throw new Error('AuthProvider not exported');
} catch (err) {
  console.warn('AuthContext missing – using fallback provider', err);
  // Fallback: simple context that provides a dummy value
  const { createContext, useContext } = React;
  const DummyAuthContext = createContext({ user: null });
  AuthProvider = ({ children }) => (
    <DummyAuthContext.Provider value={{ user: null }}>
      {children}
    </DummyAuthContext.Provider>
  );
}

try {
  const ThemeContextModule = require('./contexts/ThemeContext');
  ThemeProvider = ThemeContextModule.ThemeProvider || ThemeContextModule.default;
  if (!ThemeProvider) throw new Error('ThemeProvider not exported');
} catch (err) {
  console.warn('ThemeContext missing – using fallback provider', err);
  const { createContext } = React;
  const DummyThemeContext = createContext({ theme: 'light' });
  ThemeProvider = ({ children }) => (
    <DummyThemeContext.Provider value={{ theme: 'light' }}>
      {children}
    </DummyThemeContext.Provider>
  );
}

// ----------------------------------------------------------------------
// 2. STABILIZED PERFORMANCE MONITOR
// ----------------------------------------------------------------------
class PerformanceMonitor {
  constructor() {
    this.config = {
      sampleRate: 1.0,
      endpoints: { analytics: '/api/analytics' }
    };
    // Bind methods to ensure `this` is correct
    this.trackRender = this.trackRender.bind(this);
    this.recordError = this.recordError.bind(this);
    this.init();
  }

  init() {
    if (typeof window !== 'undefined' && window.performance?.memory) {
      // (Optional) store memory info if needed
    }
  }

  trackRender(componentName) {
    // Silent in production, verbose only in development
    if (process.env.NODE_ENV === 'development') {
      // console.debug(`[Perf] Render: ${componentName}`);
    }
  }

  recordError(error) {
    console.error('[PerformanceMonitor]', error);
  }
}

export const performanceMonitor = new PerformanceMonitor();

// ----------------------------------------------------------------------
// 3. FIXED HOC (no infinite loops)
// ----------------------------------------------------------------------
const withPerformance = (WrappedComponent) => {
  const componentName = WrappedComponent.displayName || WrappedComponent.name || 'Component';

  function WithPerformance(props) {
    const renderCount = useRef(0);

    // Runs once per mount (empty dependency array)
    useEffect(() => {
      performanceMonitor.trackRender(componentName);
    }, []);

    renderCount.current++;
    return <WrappedComponent {...props} />;
  }

  WithPerformance.displayName = `WithPerf(${componentName})`;
  return WithPerformance;
};

// ----------------------------------------------------------------------
// 4. ENHANCED ERROR BOUNDARY (with retry)
// ----------------------------------------------------------------------
class ErrorBoundary extends React.Component {
  constructor(props) {
    super(props);
    this.state = { hasError: false, errorInfo: null };
  }

  static getDerivedStateFromError(error) {
    return { hasError: true, errorInfo: error };
  }

  componentDidCatch(error, info) {
    console.error('ErrorBoundary caught:', error, info);
    // Optionally send to analytics
    performanceMonitor.recordError(error);
  }

  handleRetry = () => {
    this.setState({ hasError: false, errorInfo: null });
    // Optional: reload specific parts or clear caches
  };

  render() {
    if (this.state.hasError) {
      return (
        <div style={{ padding: '2rem', textAlign: 'center', background: '#1a1a1a', color: '#fff' }}>
          <h1>⚠️ Something went wrong</h1>
          <p>{this.state.errorInfo?.message || 'Unknown error'}</p>
          <button
            onClick={this.handleRetry}
            style={{
              marginTop: '1rem',
              padding: '0.5rem 1rem',
              background: '#646cff',
              border: 'none',
              borderRadius: '4px',
              color: '#fff',
              cursor: 'pointer',
              fontSize: '1rem',
            }}
          >
            Try again
          </button>
          <button
            onClick={() => window.location.reload()}
            style={{
              marginLeft: '1rem',
              padding: '0.5rem 1rem',
              background: '#444',
              border: 'none',
              borderRadius: '4px',
              color: '#fff',
              cursor: 'pointer',
            }}
          >
            Reload page
          </button>
        </div>
      );
    }
    return this.props.children;
  }
}

// ----------------------------------------------------------------------
// 5. ROOT COMPONENT (proper provider nesting)
// ----------------------------------------------------------------------
const Root = () => {
  return (
    <ErrorBoundary>
      <AuthProvider>
        <ThemeProvider>
          <App />
        </ThemeProvider>
      </AuthProvider>
    </ErrorBoundary>
  );
};

const MonitoredRoot = withPerformance(Root);

// ----------------------------------------------------------------------
// 6. RENDER
// ----------------------------------------------------------------------
ReactDOM.createRoot(document.getElementById('root')).render(
  <React.StrictMode>
    <MonitoredRoot />
  </React.StrictMode>
);
